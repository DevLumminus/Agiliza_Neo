    <!-- 🔹 BLOCO PRINCIPAL CENTRALIZADO -->
    <LinearLayout
        android:id="@+id/blocoPrincipal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/barraSuperior"
        app:layout_constraintBottom_toTopOf="@id/menuPrincipal"
        app:layout_constraintVertical_bias="0.35"> <!-- centraliza verticalmente -->

        <!-- 🔹 TEXTO DE BOAS-VINDAS -->
        <TextView
            android:id="@+id/Welcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/alatsi"
            android:text="Bem-Vindo ao Agiliza Neo"
            android:textColor="?attr/colorOnSurface"
            android:textSize="36sp"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <!-- 🔹 TEXTO INTRO -->
        <TextView
            android:id="@+id/TextoIntro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/alatsi"
            android:gravity="center"
            android:text="Se está procurando um facilitador para as suas contas básicas como água, luz, telefone, etc, você está no lugar certo."
            android:textColor="?attr/colorOnSurface"
            android:textSize="18sp"
            android:layout_marginBottom="24dp"/>

        <!-- 🔹 BOTÃO PRINCIPAL -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/BotaoAdd"
            android:layout_width="260dp"
            android:layout_height="72dp"
            android:background="@drawable/botao_selector"
            android:text="Vamos Agilizar"
            android:textColor="@color/text_botao_selector"
            android:textSize="20sp"
            android:fontFamily="@font/alatsi"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:gravity="center_vertical"
            app:backgroundTint="@null"
            app:icon="@drawable/ic_plus"
            app:iconGravity="textStart"
            app:iconPadding="16dp"
            app:iconSize="26dp"
            app:cornerRadius="0dp"
            app:rippleColor="?attr/colorPrimary"/>
    </LinearLayout>

